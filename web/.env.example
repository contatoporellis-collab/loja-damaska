# ── amoCRM (основной канал доставки заявок) ─────────────────────
# Поддомен вашего аккаунта amoCRM (без .amocrm.ru). Пример: damaska
AMOCRM_SUBDOMAIN=
# Долгосрочный токен интеграции: Настройки → Интеграции → создать
# интеграцию → вкладка «Ключи и доступы» → «Долгосрочный токен».
AMOCRM_ACCESS_TOKEN=

# ── E-mail (резервный канал) через HTTPS (Unisender Go) ──────────
# SMTP-порты у хостинга закрыты, поэтому используем HTTP API (порт 443).
# Скопируйте этот файл в .env.local для локали и задайте эти же переменные
# в панели Timeweb (App → «Переменные окружения») для продакшена.

# API-ключ Unisender Go (обязателен). Личный кабинет → «Настройки» → «API-ключи».
MAIL_API_KEY=

# Куда присылать заявки. Необязательно — по умолчанию damaskad@yandex.ru.
MAIL_TO=damaskad@yandex.ru

# Адрес отправителя. Домен должен быть ПОДТВЕРЖДЁН в Unisender Go
# (иначе письма не отправятся). Необязательно — по умолчанию zayavki@damaska123.ru.
MAIL_FROM=zayavki@damaska123.ru

# Имя отправителя в письме. Необязательно.
MAIL_FROM_NAME=Сайт DAMASKA

# ── Яндекс.Метрика ──────────────────────────────────────────────
# Номер счётчика Яндекс.Метрики (например 98765432). Публичная переменная —
# попадает в браузер. Пока не задана — счётчик и цели не подключаются.
NEXT_PUBLIC_YM_ID=
